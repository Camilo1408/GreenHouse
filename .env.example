# ============================================================
#  GreenHouse Manager — Variables de entorno
#  Copia este archivo como: .env  (en la raíz del proyecto)
#  El archivo .env está en .gitignore — NUNCA lo subas a Git
# ============================================================

# ── Base de datos PostgreSQL ─────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/greenhouse_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Google OAuth2 ────────────────────────────────────────────
# Obtén estas credenciales en: console.cloud.google.com
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu-client-secret

# ── Correo Gmail (verificación de cuenta) ────────────────────
# Usa una "Contraseña de aplicación", NO tu contraseña normal
# Activar en: myaccount.google.com → Seguridad → Contraseñas de aplicación
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-app-password-16-chars

# ── URLs (no cambiar en desarrollo local) ────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080

# ── Taiga (para pruebas de integración y taiga-upload.py) ────
TAIGA_URL=https://api.taiga.io/api/v1
TAIGA_USERNAME=tu-usuario-taiga
TAIGA_PASSWORD=tu-contraseña-taiga
TAIGA_PROJECT_SLUG=cesar_camilo-greenhouse-manager
