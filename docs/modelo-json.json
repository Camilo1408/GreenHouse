{
  "$schema": "https://json-schema.org/draft/2020-12",
  "title": "GreenHouse Manager — Modelo de Datos JSON",
  "description": "Esquema completo de las entidades del sistema de gestión de invernaderos",
  "version": "2.0.0",
  "authors": ["[Nombres del equipo]"],
  "date": "2026",
  "changelog": [
    "v2.0.0 — Alerta: añadidos atendidoPor, notasResolucion y origen MANUAL/AUTOMATICA",
    "v2.0.0 — POST /api/alertas para creación manual (novedades de falla en zona)",
    "v2.0.0 — GET /api/empleados/me accesible a todos los roles autenticados",
    "v2.0.0 — RBAC: ADMINISTRADOR, SUPERVISOR, EMPLEADO con permisos diferenciados",
    "v2.0.0 — Tratamiento.tipoTratamiento: añadido REVISION para novedades de enfermedad",
    "v2.0.0 — Sensor: umbralMin/umbralMax para generación automática de alertas"
  ],

  "roles": {
    "ADMINISTRADOR": {
      "description": "Acceso completo a todas las funciones del sistema",
      "permissions": ["CREATE", "READ", "UPDATE", "DELETE"],
      "exclusive_access": ["Empleados (listado completo)", "DELETE en todas las entidades"]
    },
    "SUPERVISOR": {
      "description": "Puede crear y editar entidades pero no eliminar",
      "permissions": ["CREATE", "READ", "UPDATE"],
      "denied": ["DELETE en cualquier entidad", "Gestión de empleados"]
    },
    "EMPLEADO": {
      "description": "Acceso operativo: cosechas, alertas, novedades",
      "permissions": ["READ"],
      "additional": [
        "PATCH /api/alertas/{id}/atender — cambiar estado de alerta",
        "PATCH /api/alertas/{id}/descartar — descartar alerta",
        "POST /api/cosechas — registrar cosecha propia",
        "POST /api/tratamientos — reportar novedad de enfermedad",
        "POST /api/alertas — reportar novedad de falla en zona",
        "GET /api/empleados/me — consultar su propio perfil"
      ]
    }
  },

  "entities": {

    "Zona": {
      "table": "zona",
      "description": "Área física del invernadero con condiciones ambientales homogéneas",
      "properties": {
        "id":                  { "type": "integer", "description": "Identificador único" },
        "nombre":              { "type": "string",  "maxLength": 100, "description": "Nombre descriptivo de la zona" },
        "dimensionM2":         { "type": "number",  "minimum": 0.1,  "description": "Dimensión en metros cuadrados" },
        "capacidadMaxPlantas": { "type": "integer", "minimum": 1,    "description": "Máximo de plantas permitidas" },
        "estado":              { "type": "string",  "enum": ["ACTIVA", "EN_MANTENIMIENTO", "INACTIVA"] },
        "ubicacion":           { "type": "string",  "maxLength": 200, "description": "Descripción física del sector" }
      },
      "required": ["nombre", "estado"],
      "rbac": {
        "CREATE": "ADMINISTRADOR, SUPERVISOR",
        "READ":   "todos los roles",
        "UPDATE": "ADMINISTRADOR, SUPERVISOR",
        "DELETE": "ADMINISTRADOR"
      },
      "example": {
        "id": 1,
        "nombre": "Zona A - Tomates",
        "dimensionM2": 120.0,
        "capacidadMaxPlantas": 200,
        "estado": "ACTIVA",
        "ubicacion": "Sector Norte"
      }
    },

    "TipoPlanta": {
      "table": "tipo_planta",
      "description": "Catálogo de especies cultivables con parámetros ambientales óptimos",
      "properties": {
        "id":               { "type": "integer", "description": "Identificador único" },
        "nombre":           { "type": "string",  "maxLength": 100, "description": "Nombre de la especie" },
        "descripcion":      { "type": "string",  "maxLength": 500 },
        "temperaturaMin":   { "type": "number",  "minimum": 0.0, "maximum": 60.0, "description": "Temperatura mínima óptima en °C" },
        "temperaturaMax":   { "type": "number",  "minimum": 0.0, "maximum": 60.0, "description": "Temperatura máxima óptima en °C" },
        "humedadMin":       { "type": "number",  "minimum": 0.0, "maximum": 100.0, "description": "Humedad relativa mínima óptima %" },
        "humedadMax":       { "type": "number",  "minimum": 0.0, "maximum": 100.0, "description": "Humedad relativa máxima óptima %" },
        "cicloDias":        { "type": "integer", "minimum": 1, "description": "Días de siembra a cosecha" },
        "cuidadosEspeciales": { "type": "string", "maxLength": 500 }
      },
      "required": ["nombre", "temperaturaMin", "temperaturaMax", "humedadMin", "humedadMax", "cicloDias"],
      "rbac": {
        "CREATE": "ADMINISTRADOR, SUPERVISOR",
        "READ":   "todos los roles",
        "UPDATE": "ADMINISTRADOR, SUPERVISOR",
        "DELETE": "ADMINISTRADOR"
      },
      "example": {
        "id": 1,
        "nombre": "Tomate Cherry",
        "descripcion": "Tomate de fruto pequeño, ideal para ensaladas",
        "temperaturaMin": 18.0,
        "temperaturaMax": 28.0,
        "humedadMin": 60.0,
        "humedadMax": 80.0,
        "cicloDias": 75,
        "cuidadosEspeciales": "Tutorear cuando alcance 30cm. Podar brotes laterales."
      }
    },

    "Empleado": {
      "table": "empleado",
      "description": "Usuario del sistema con rol y método de autenticación",
      "properties": {
        "id":              { "type": "integer" },
        "nombreCompleto":  { "type": "string",  "maxLength": 150 },
        "email":           { "type": "string",  "format": "email" },
        "rol":             { "type": "string",  "enum": ["ADMINISTRADOR", "SUPERVISOR", "EMPLEADO"] },
        "telefono":        { "type": "string",  "maxLength": 20 },
        "estado":          { "type": "string",  "enum": ["ACTIVO", "INACTIVO"], "default": "ACTIVO" },
        "fechaIngreso":    { "type": "string",  "format": "date" },
        "emailVerificado": { "type": "boolean", "default": false },
        "authProvider":    { "type": "string",  "enum": ["LOCAL", "GOOGLE"], "default": "LOCAL" }
      },
      "required": ["nombreCompleto", "email", "rol"],
      "note": "passwordHash se omite del JSON por seguridad",
      "rbac": {
        "CREATE": "ADMINISTRADOR",
        "READ (listado)": "ADMINISTRADOR",
        "READ (propio, /me)": "todos los roles autenticados",
        "UPDATE": "ADMINISTRADOR",
        "DELETE": "ADMINISTRADOR"
      },
      "example": {
        "id": 1,
        "nombreCompleto": "Carlos Administrador",
        "email": "admin@greenhouse.com",
        "rol": "ADMINISTRADOR",
        "telefono": "3001234567",
        "estado": "ACTIVO",
        "fechaIngreso": "2024-01-15",
        "emailVerificado": true,
        "authProvider": "LOCAL"
      }
    },

    "Planta": {
      "table": "planta",
      "description": "Ejemplar individual de planta con trazabilidad completa de su ciclo de vida",
      "properties": {
        "id":           { "type": "integer" },
        "codigo":       { "type": "string",  "maxLength": 50, "description": "Código físico único (ej: TOM-001)" },
        "tipoPlanta":   { "$ref": "#/entities/TipoPlanta" },
        "zona":         { "$ref": "#/entities/Zona" },
        "fechaSiembra": { "type": "string",  "format": "date" },
        "estado":       { "type": "string",  "enum": ["SEMBRADA", "EN_CRECIMIENTO", "LISTA_PARA_COSECHAR", "COSECHADA", "MUERTA"] },
        "observaciones":{ "type": "string",  "maxLength": 500 }
      },
      "required": ["codigo", "tipoPlanta", "zona", "fechaSiembra", "estado"],
      "rbac": {
        "CREATE": "ADMINISTRADOR, SUPERVISOR",
        "READ":   "todos los roles",
        "UPDATE": "ADMINISTRADOR, SUPERVISOR",
        "DELETE": "ADMINISTRADOR"
      },
      "example": {
        "id": 1,
        "codigo": "TOM-001",
        "tipoPlanta": { "id": 1, "nombre": "Tomate Cherry" },
        "zona": { "id": 1, "nombre": "Zona A - Tomates" },
        "fechaSiembra": "2026-03-01",
        "estado": "LISTA_PARA_COSECHAR",
        "observaciones": null
      }
    },

    "Sensor": {
      "table": "sensor",
      "description": "Dispositivo físico que mide variables ambientales en una zona",
      "properties": {
        "id":               { "type": "integer" },
        "codigo":           { "type": "string", "maxLength": 50 },
        "tipoSensor":       { "type": "string", "enum": ["TEMPERATURA", "HUMEDAD", "PH", "CO2", "LUZ"] },
        "zona":             { "$ref": "#/entities/Zona" },
        "estado":           { "type": "string", "enum": ["ACTIVO", "INACTIVO", "EN_MANTENIMIENTO"], "default": "ACTIVO" },
        "fechaInstalacion": { "type": "string", "format": "date" },
        "umbralMin":        { "type": "number", "description": "Valor mínimo aceptable. Lecturas por debajo generan alerta automática." },
        "umbralMax":        { "type": "number", "description": "Valor máximo aceptable. Lecturas por encima generan alerta automática." }
      },
      "required": ["codigo", "tipoSensor", "zona"],
      "rbac": {
        "CREATE": "ADMINISTRADOR, SUPERVISOR",
        "READ":   "todos los roles",
        "UPDATE": "ADMINISTRADOR, SUPERVISOR",
        "DELETE": "ADMINISTRADOR"
      },
      "example": {
        "id": 1,
        "codigo": "SENS-TA-01",
        "tipoSensor": "TEMPERATURA",
        "zona": { "id": 1, "nombre": "Zona A - Tomates" },
        "estado": "ACTIVO",
        "fechaInstalacion": "2024-01-01",
        "umbralMin": 18.0,
        "umbralMax": 28.0
      }
    },

    "LecturaSensor": {
      "table": "lectura_sensor",
      "description": "Medición puntual registrada por un sensor en un momento dado. Si el valor supera umbralMin/umbralMax del sensor, se genera una Alerta automáticamente.",
      "properties": {
        "id":        { "type": "integer" },
        "sensor":    { "$ref": "#/entities/Sensor" },
        "valor":     { "type": "number" },
        "unidad":    { "type": "string", "maxLength": 20, "examples": ["°C", "%", "pH", "ppm", "lux"] },
        "fechaHora": { "type": "string", "format": "date-time" },
        "fuente":    { "type": "string", "enum": ["AUTOMATICA", "MANUAL"] }
      },
      "required": ["sensor", "valor", "unidad", "fechaHora", "fuente"],
      "example": {
        "id": 1,
        "sensor": { "id": 1, "codigo": "SENS-TA-01" },
        "valor": 31.0,
        "unidad": "°C",
        "fechaHora": "2026-05-16T20:00:00",
        "fuente": "MANUAL"
      }
    },

    "Alerta": {
      "table": "alerta",
      "description": "Aviso generado automáticamente cuando una lectura supera los umbrales del sensor, o manualmente por un empleado para reportar una falla de sistema en zona (novedad).",
      "properties": {
        "id":               { "type": "integer" },
        "tipo":             { "type": "string",  "maxLength": 200, "description": "Categoría del evento (ej: UMBRAL_TEMPERATURA, FALLA_SISTEMA, FALLA_REFRIGERACION)" },
        "severidad":        { "type": "string",  "enum": ["BAJA", "MEDIA", "ALTA", "CRITICA"] },
        "zona":             { "$ref": "#/entities/Zona" },
        "sensor":           { "$ref": "#/entities/Sensor", "nullable": true, "description": "null para alertas manuales (novedades)" },
        "fechaGeneracion":  { "type": "string",  "format": "date-time" },
        "estado":           { "type": "string",  "enum": ["PENDIENTE", "ATENDIDA", "DESCARTADA"], "default": "PENDIENTE" },
        "descripcion":      { "type": "string",  "maxLength": 500 },
        "atendidoPor":      { "$ref": "#/entities/Empleado", "nullable": true, "description": "Empleado que gestionó la alerta" },
        "notasResolucion":  { "type": ["string", "null"], "maxLength": 1000, "description": "Notas de resolución o descarte escritas por el empleado responsable" },
        "origen":           { "type": "string",  "enum": ["AUTOMATICA", "MANUAL"], "default": "AUTOMATICA", "description": "MANUAL indica que es una novedad reportada por un empleado" }
      },
      "required": ["tipo", "severidad", "zona", "fechaGeneracion"],
      "rbac": {
        "CREATE (manual)": "todos los roles autenticados",
        "READ":   "todos los roles",
        "PATCH atender/descartar": "todos los roles autenticados",
        "DELETE": "ADMINISTRADOR"
      },
      "example_automatica": {
        "id": 1,
        "tipo": "UMBRAL_TEMPERATURA",
        "severidad": "ALTA",
        "zona": { "id": 1, "nombre": "Zona A - Tomates" },
        "sensor": { "id": 1, "codigo": "SENS-TA-01" },
        "fechaGeneracion": "2026-05-16T20:00:00",
        "estado": "PENDIENTE",
        "descripcion": "Sensor SENS-TA-01 en Zona A: temperatura 31.0°C supera el máximo de 28.0°C",
        "atendidoPor": null,
        "notasResolucion": null,
        "origen": "AUTOMATICA"
      },
      "example_manual_novedad": {
        "id": 42,
        "tipo": "FALLA_REFRIGERACION",
        "severidad": "CRITICA",
        "zona": { "id": 2, "nombre": "Zona B - Lechugas" },
        "sensor": null,
        "fechaGeneracion": "2026-05-27T09:30:00",
        "estado": "PENDIENTE",
        "descripcion": "El sistema de refrigeración de la Zona B no responde. Temperatura subiendo.",
        "atendidoPor": null,
        "notasResolucion": null,
        "origen": "MANUAL"
      }
    },

    "Cosecha": {
      "table": "cosecha",
      "description": "Registro de producción obtenida de una planta con datos de calidad y destino",
      "properties": {
        "id":            { "type": "integer" },
        "planta":        { "$ref": "#/entities/Planta" },
        "empleado":      { "$ref": "#/entities/Empleado" },
        "fechaCosecha":  { "type": "string", "format": "date" },
        "pesoKg":        { "type": "number", "minimum": 0.01 },
        "calidad":       { "type": "string", "enum": ["A", "B", "C"], "description": "A=Premium, B=Estándar, C=Descarte" },
        "destino":       { "type": "string", "enum": ["VENTA", "CONSUMO_INTERNO", "DESCARTE"] },
        "observaciones": { "type": "string", "maxLength": 500 }
      },
      "required": ["planta", "empleado", "fechaCosecha", "pesoKg", "calidad", "destino"],
      "rbac": {
        "CREATE": "todos los roles autenticados",
        "READ":   "todos los roles",
        "UPDATE": "ADMINISTRADOR, SUPERVISOR",
        "DELETE": "ADMINISTRADOR"
      },
      "example": {
        "id": 1,
        "planta": { "id": 5, "codigo": "TOM-005" },
        "empleado": { "id": 3, "nombreCompleto": "Juan Pérez" },
        "fechaCosecha": "2026-05-14",
        "pesoKg": 6.0,
        "calidad": "A",
        "destino": "VENTA",
        "observaciones": "Mejor cosecha del mes"
      }
    },

    "Tratamiento": {
      "table": "tratamiento",
      "description": "Intervención aplicada a una planta. El tipo REVISION se usa para reportar novedades de enfermedad (requiere descripción de síntomas en resultadoObservado).",
      "properties": {
        "id":                 { "type": "integer" },
        "planta":             { "$ref": "#/entities/Planta" },
        "empleado":           { "$ref": "#/entities/Empleado" },
        "tipoTratamiento":    { "type": "string", "enum": ["FERTILIZACION", "PESTICIDA", "PODA", "RIEGO_MANUAL", "REVISION"], "description": "REVISION = novedad de enfermedad reportada por empleado" },
        "productoUtilizado":  { "type": "string", "maxLength": 150 },
        "dosis":              { "type": "string", "maxLength": 100 },
        "fechaHora":          { "type": "string", "format": "date-time" },
        "resultadoObservado": { "type": "string", "maxLength": 500, "description": "Descripción de síntomas para novedades de tipo REVISION" }
      },
      "required": ["planta", "empleado", "tipoTratamiento", "fechaHora"],
      "rbac": {
        "CREATE": "todos los roles autenticados",
        "READ":   "todos los roles",
        "UPDATE": "ADMINISTRADOR, SUPERVISOR",
        "DELETE": "ADMINISTRADOR"
      },
      "example": {
        "id": 1,
        "planta": { "id": 1, "codigo": "TOM-001" },
        "empleado": { "id": 3, "nombreCompleto": "Juan Pérez" },
        "tipoTratamiento": "REVISION",
        "productoUtilizado": "",
        "dosis": "",
        "fechaHora": "2026-05-27T09:15:00",
        "resultadoObservado": "Manchas amarillas en hojas inferiores — posible deficiencia de nitrógeno"
      }
    },

    "Turno": {
      "table": "turno",
      "description": "Asignación horaria de un empleado a una zona del invernadero",
      "properties": {
        "id":                   { "type": "integer" },
        "empleado":             { "$ref": "#/entities/Empleado" },
        "zona":                 { "$ref": "#/entities/Zona" },
        "fechaHoraInicio":      { "type": "string", "format": "date-time" },
        "fechaHoraFin":         { "type": ["string", "null"], "format": "date-time", "description": "null si el turno está en curso" },
        "actividadesRealizadas":{ "type": "string", "maxLength": 1000 }
      },
      "required": ["empleado", "zona", "fechaHoraInicio"],
      "rbac": {
        "CREATE": "ADMINISTRADOR, SUPERVISOR",
        "READ":   "todos los roles",
        "UPDATE": "ADMINISTRADOR, SUPERVISOR",
        "DELETE": "ADMINISTRADOR"
      },
      "example": {
        "id": 1,
        "empleado": { "id": 3, "nombreCompleto": "Juan Pérez" },
        "zona": { "id": 1, "nombre": "Zona A - Tomates" },
        "fechaHoraInicio": "2026-05-15T07:00:00",
        "fechaHoraFin": "2026-05-15T15:00:00",
        "actividadesRealizadas": "Riego manual zona A, revisión de sensores, registro de lecturas"
      }
    }
  },

  "api_endpoints": {
    "auth": [
      "POST /api/auth/register",
      "GET  /api/auth/verify?token={token}",
      "POST /api/auth/login",
      "POST /api/auth/logout",
      "GET  /api/auth/me",
      "POST /api/auth/resend-verification?email={email}"
    ],
    "zonas": [
      "GET    /api/zonas",
      "GET    /api/zonas/{id}",
      "POST   /api/zonas                   [ADMIN, SUPERVISOR]",
      "PUT    /api/zonas/{id}              [ADMIN, SUPERVISOR]",
      "DELETE /api/zonas/{id}             [ADMIN]"
    ],
    "plantas": [
      "GET    /api/plantas",
      "GET    /api/plantas/{id}",
      "GET    /api/plantas/zona/{zonaId}",
      "GET    /api/plantas/estado/{estado}",
      "POST   /api/plantas                 [ADMIN, SUPERVISOR]",
      "PUT    /api/plantas/{id}            [ADMIN, SUPERVISOR]",
      "DELETE /api/plantas/{id}           [ADMIN]"
    ],
    "alertas": [
      "GET    /api/alertas",
      "GET    /api/alertas/pendientes",
      "GET    /api/alertas/count/pendientes",
      "POST   /api/alertas                 [todos los roles — novedad de falla en zona]",
      "PATCH  /api/alertas/{id}/atender    [todos los roles — cuerpo: {notas?}]",
      "PATCH  /api/alertas/{id}/descartar  [todos los roles — cuerpo: {notas?}]"
    ],
    "cosechas": [
      "GET  /api/cosechas",
      "GET  /api/cosechas/periodo?inicio={}&fin={}",
      "GET  /api/cosechas/estadisticas/mes?year={}&month={}",
      "POST /api/cosechas                  [todos los roles autenticados]"
    ],
    "empleados": [
      "GET    /api/empleados               [ADMIN]",
      "GET    /api/empleados/{id}          [ADMIN]",
      "GET    /api/empleados/me            [todos los roles autenticados]",
      "POST   /api/empleados               [ADMIN]",
      "PUT    /api/empleados/{id}          [ADMIN]",
      "DELETE /api/empleados/{id}         [ADMIN]"
    ],
    "tratamientos": [
      "GET    /api/tratamientos",
      "GET    /api/tratamientos/planta/{plantaId}",
      "POST   /api/tratamientos            [todos los roles — para novedades REVISION]",
      "PUT    /api/tratamientos/{id}       [ADMIN, SUPERVISOR]",
      "DELETE /api/tratamientos/{id}      [ADMIN]"
    ],
    "sensores": [
      "GET    /api/sensores",
      "GET    /api/sensores/{id}",
      "GET    /api/sensores/zona/{zonaId}",
      "POST   /api/sensores                [ADMIN, SUPERVISOR]",
      "PUT    /api/sensores/{id}           [ADMIN, SUPERVISOR]",
      "DELETE /api/sensores/{id}          [ADMIN]"
    ],
    "lecturas": [
      "GET  /api/lecturas/sensor/{sensorId}",
      "POST /api/lecturas"
    ],
    "tipos-planta": [
      "GET    /api/tipos-planta",
      "GET    /api/tipos-planta/{id}",
      "POST   /api/tipos-planta            [ADMIN, SUPERVISOR]",
      "PUT    /api/tipos-planta/{id}       [ADMIN, SUPERVISOR]",
      "DELETE /api/tipos-planta/{id}      [ADMIN]"
    ]
  },

  "relationships": {
    "Zona → Planta":         "1:N — Una zona contiene múltiples plantas",
    "Zona → Sensor":         "1:N — Una zona tiene múltiples sensores",
    "Zona → Alerta":         "1:N — Una zona puede tener múltiples alertas",
    "Zona → Turno":          "1:N — Una zona puede tener múltiples turnos",
    "Sensor → LecturaSensor":"1:N — Un sensor registra múltiples lecturas",
    "Sensor → Alerta":       "1:N (nullable) — Un sensor puede generar múltiples alertas; null para alertas manuales",
    "TipoPlanta → Planta":   "1:N — Un tipo de planta agrupa múltiples plantas",
    "Planta → Cosecha":      "1:N — Una planta puede tener múltiples cosechas",
    "Planta → Tratamiento":  "1:N — Una planta puede recibir múltiples tratamientos",
    "Empleado → Cosecha":    "1:N — Un empleado registra múltiples cosechas",
    "Empleado → Tratamiento":"1:N — Un empleado aplica múltiples tratamientos",
    "Empleado → Turno":      "1:N — Un empleado puede tener múltiples turnos",
    "Empleado → Alerta (atendidoPor)": "1:N (nullable) — Un empleado puede gestionar múltiples alertas"
  }
}
